# =============================================================================
# СЗ ДЕЛО | Юридический ИИ-агент
# Конфигурационный файл
# =============================================================================

# -----------------------------------------------------------------------------
# YANDEX GPT (основной LLM)
# -----------------------------------------------------------------------------
# Получить: https://cloud.yandex.ru/docs/iam/operations/api-key/create
YANDEX_FOLDER_ID=your_folder_id
YANDEX_API_KEY=your_api_key

# -----------------------------------------------------------------------------
# GIGA CHAT (резервный LLM)
# -----------------------------------------------------------------------------
# Получить: https://developers.sber.ru/docs/ru/gigachat/individual/auth
GIGACHAT_CREDENTIALS=your_credentials_base64

# -----------------------------------------------------------------------------
# НАСТРОЙКИ ПРИЛОЖЕНИЯ
# -----------------------------------------------------------------------------
APP_NAME=СЗ Дело | Юридический ИИ-агент
APP_ENV=production

# -----------------------------------------------------------------------------
# БАЗА ДАННЫХ И КЭШ
# -----------------------------------------------------------------------------
# Redis (опционально, для сессионной памяти)
REDIS_URL=redis://localhost:6379/0

# Путь к базе знаний
KB_PATH=data/sz_delo_base

# Путь к шаблонам
TEMPLATES_PATH=data/templates

# -----------------------------------------------------------------------------
# ЛИМИТЫ
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
MAX_CONTEXT_LENGTH=4096

# -----------------------------------------------------------------------------
# ИНСТРУКЦИЯ ПО ПОЛУЧЕНИЮ КЛЮЧЕЙ
# -----------------------------------------------------------------------------
# 1. YandexGPT:
#    - Создайте аккаунт в Yandex Cloud
#    - Создайте платёжный аккаунт
#    - Создайте сервисный аккаунт с ролью ai.languageModels.user
#    - Создайте API-ключ для сервисного аккаунта
#    - Скопируйте folder_id и api_key
#
# 2. GigaChat:
#    - Зарегистрируйтесь в Sber ID
#    - Создайте приложение в GigaChat Developer
#    - Получите client_id и client_secret
#    - Создайте credentials (base64(client_id:client_secret))
#
# 3. Скопируйте этот файл в .env и заполните значения
# -----------------------------------------------------------------------------
